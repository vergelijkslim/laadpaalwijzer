---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Laadpaal vergelijken & offerte aanvragen — LaadpaalWijzer.nl',
  description: 'Vergelijk de beste thuislaadpalen en vraag via onze partners een offerte aan bij gecertificeerde installateurs.',
};

const steps = [
  {
    number: '1',
    title: 'Kies jouw laadpaal',
    description: 'Vergelijk modellen op vermogen, slimme functies en prijs. Filter op ISDE-subsidie geschiktheid.',
  },
  {
    number: '2',
    title: 'Vind een gecertificeerde installateur',
    description: 'Via onze partners vind je erkende installateurs bij jou in de buurt. Aanvraag is gratis en vrijblijvend.',
  },
  {
    number: '3',
    title: 'Ontvang en vergelijk offertes',
    description: 'Ontvang meerdere offertes inclusief materiaalkosten, arbeidskosten en subsidie-begeleiding.',
  },
];

const providers = [
  {
    name: 'Eneco Laadpaal',
    description: 'Complete laadoplossing inclusief installatie. Geschikt voor alle populaire EV-merken.',
    features: ['Inclusief installatie', 'ISDE-subsidie begeleiding', 'App-sturing', '3 jaar garantie'],
    url: 'https://www.eneco.nl/energieproducten/elektrisch-rijden/',
    cta: 'Offerte aanvragen',
    featured: true,
  },
  {
    name: 'Vattenfall Laadpaal',
    description: 'Smart charging met integratie voor zonnepanelen. Populair bij PHEV en full EV rijders.',
    features: ['Slim laden met zonnepanelen', 'Dalurenladen automatisch', 'RFID-kaart', '2 jaar garantie'],
    url: 'https://www.vattenfall.nl/laadpaal/laadpaal-thuis/',
    cta: 'Offerte aanvragen',
    featured: false,
  },
  {
    name: 'Wallbox via installateur',
    description: 'Professionele installatie van Wallbox Pulsar Plus of Commander 2 door erkend installateur.',
    features: ['Beste prijs-kwaliteit', 'Meerdere merken', 'ISDE-geschikt', 'Installatiecertificaat'],
    url: 'https://www.wallbox.com/nl_NL/',
    cta: 'Vergelijk via installateur',
    featured: false,
  },
];
---

<BaseLayout
  title="Laadpaal vergelijken & offerte aanvragen"
  description="Vergelijk thuislaadpalen en vraag een vrijblijvende installatie-offerte aan bij gecertificeerde installateurs in jouw regio."
  structuredData={structuredData}
>
  <section class="page-hero">
    <div class="container hero-content">
      <span class="hero-badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        Offerte aanvragen
      </span>
      <h1>Laadpaal kopen en laten installeren</h1>
      <p class="hero-sub">
        Vergelijk laadpalen en vind een gecertificeerde installateur bij jou in de buurt.
        Vraag gratis en vrijblijvend offertes aan — inclusief ISDE-subsidie begeleiding.
      </p>
    </div>
  </section>

  <section class="steps-section">
    <div class="container">
      <h2 class="section-title">Zo werkt het</h2>
      <div class="steps-grid">
        {steps.map((step) => (
          <div class="step-card">
            <div class="step-number">{step.number}</div>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="providers-section">
    <div class="container">
      <h2 class="section-title">Vergelijk populaire opties</h2>
      <p class="section-sub">We werken samen met gecertificeerde partners. Aanvragen zijn gratis en vrijblijvend.</p>
      <div class="providers-grid">
        {providers.map((provider) => (
          <div class={`provider-card ${provider.featured ? 'provider-featured' : ''}`}>
            {provider.featured && <div class="provider-badge">Meest aangevraagd</div>}
            <h3>{provider.name}</h3>
            <p>{provider.description}</p>
            <ul class="provider-features">
              {provider.features.map((f) => (
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                  {f}
                </li>
              ))}
            </ul>
            <a href={provider.url} class={provider.featured ? 'btn btn-cta' : 'btn btn-primary'} target="_blank" rel="noopener noreferrer sponsored">
              {provider.cta} →
            </a>
          </div>
        ))}
      </div>
      <p class="providers-disclaimer">
        <small>* Wij ontvangen mogelijk een vergoeding wanneer je via onze links een aanvraag doet. Dit heeft geen invloed op onze beoordeling. Prijzen en beschikbaarheid kunnen afwijken.</small>
      </p>
    </div>
  </section>

  <section class="subsidie-section">
    <div class="container">
      <div class="subsidie-card">
        <div class="subsidie-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="subsidie-text">
          <h3>ISDE-subsidie: tot €1.400 terug</h3>
          <p>Via de ISDE-regeling (Investeringssubsidie Duurzame Energie) kun je in 2026 tot €1.400 subsidie ontvangen op een erkende thuislaadpaal met slimme laadoptie. De meeste installateurs regelen dit voor je.</p>
          <a href="/laadpalen/laadpaal-subsidie-2026/" class="btn btn-primary">Lees meer over ISDE-subsidie</a>
        </div>
      </div>
    </div>
  </section>

  <section class="compare-cta">
    <div class="container">
      <div class="compare-card">
        <h2>Liever eerst zelf vergelijken?</h2>
        <p>Bekijk onze onafhankelijke vergelijking van de populairste thuislaadpalen, met scores op laadsnelheid, app-kwaliteit en prijs-kwaliteit.</p>
        <a href="/vergelijkingen/" class="btn btn-cta">Bekijk de vergelijking</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(135deg, #052e16 0%, #14532d 40%, #16a34a 100%);
    color: #fff;
    padding: 4rem 0 5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(74,222,128,0.12) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-content { position: relative; }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 0.375rem;
    padding: 0.375rem 1rem;
    background: rgba(74,222,128,0.2); border: 1px solid rgba(74,222,128,0.4);
    border-radius: 9999px; font-size: 0.8125rem; font-weight: 600;
    margin-bottom: 1.5rem; backdrop-filter: blur(4px); color: #bbf7d0;
  }
  .page-hero h1 { color: #fff; font-size: 2.25rem; margin-bottom: 1.25rem; }
  .hero-sub { font-size: 1.0625rem; opacity: 0.85; line-height: 1.7; max-width: 560px; margin: 0 auto; }
  @media (min-width: 768px) {
    .page-hero { padding: 6rem 0 7rem; }
    .page-hero h1 { font-size: 3rem; }
  }

  .section-title { text-align: center; margin-bottom: 0.5rem; }
  .section-sub { text-align: center; color: var(--color-text-light); margin-bottom: 2.5rem; font-size: 1rem; }

  .steps-section { padding: 4rem 0; background: var(--color-bg-alt); }
  .steps-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; margin-top: 2rem; }
  @media (min-width: 768px) { .steps-grid { grid-template-columns: repeat(3, 1fr); } }
  .step-card { text-align: center; padding: 2rem 1.5rem; }
  .step-number {
    display: inline-flex; align-items: center; justify-content: center;
    width: 48px; height: 48px; border-radius: 50%; background: var(--color-primary);
    color: #fff; font-size: 1.25rem; font-weight: 700; font-family: var(--font-serif); margin-bottom: 1rem;
  }
  .step-card h3 { font-family: var(--font-sans); font-size: 1.0625rem; font-weight: 600; margin-bottom: 0.5rem; }
  .step-card p { color: var(--color-text-light); font-size: 0.9375rem; line-height: 1.6; }

  .providers-section { padding: 4rem 0; }
  .providers-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
  @media (min-width: 768px) { .providers-grid { grid-template-columns: repeat(3, 1fr); } }
  .provider-card {
    border: 1px solid var(--color-border); border-radius: var(--radius-xl); padding: 2rem;
    background: #fff; display: flex; flex-direction: column; gap: 1rem; position: relative;
  }
  .provider-featured { border-color: var(--color-primary); box-shadow: 0 0 0 1px var(--color-primary); }
  .provider-badge {
    position: absolute; top: -12px; left: 1.5rem;
    padding: 0.25rem 0.75rem; background: var(--color-primary); color: #fff;
    border-radius: 9999px; font-size: 0.75rem; font-weight: 700;
  }
  .provider-card h3 { font-family: var(--font-sans); font-size: 1.125rem; font-weight: 700; }
  .provider-card > p { color: var(--color-text-light); font-size: 0.9375rem; line-height: 1.6; flex: 1; }
  .provider-features { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
  .provider-features li { display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; color: var(--color-text-light); }
  .provider-features svg { color: var(--color-primary); flex-shrink: 0; }
  .provider-card .btn { width: 100%; justify-content: center; }
  .providers-disclaimer { text-align: center; margin-top: 1.5rem; color: var(--color-text-muted); font-size: 0.8125rem; }

  .subsidie-section { padding: 3rem 0; background: var(--color-bg-alt); }
  .subsidie-card {
    display: flex; flex-direction: column; gap: 1.5rem; align-items: flex-start;
    background: #fff; border: 1px solid var(--color-border); border-radius: var(--radius-xl);
    padding: 2rem; max-width: 900px; margin: 0 auto;
  }
  @media (min-width: 768px) { .subsidie-card { flex-direction: row; align-items: center; } }
  .subsidie-icon {
    display: flex; align-items: center; justify-content: center;
    width: 64px; height: 64px; min-width: 64px;
    background: var(--color-primary-light); border-radius: var(--radius-lg); color: var(--color-primary);
  }
  .subsidie-text { flex: 1; }
  .subsidie-text h3 { font-family: var(--font-sans); font-size: 1.125rem; font-weight: 600; margin-bottom: 0.375rem; }
  .subsidie-text p { color: var(--color-text-light); font-size: 0.9375rem; line-height: 1.6; margin-bottom: 1rem; }

  .compare-cta { padding: 4rem 0; }
  .compare-card {
    text-align: center; background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
    border: 1px solid #86efac; border-radius: var(--radius-xl);
    padding: 3rem 2rem; max-width: 700px; margin: 0 auto;
  }
  .compare-card h2 { margin-bottom: 0.75rem; }
  .compare-card p { color: var(--color-text-light); margin-bottom: 1.75rem; line-height: 1.6; }
</style>
