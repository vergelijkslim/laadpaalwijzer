---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Vergelijk Uw Laadpaal',
  url: Astro.site?.href,
  description: 'De onafhankelijke gids voor laadpalen thuis in Nederland',
  inLanguage: 'nl',
};

const allArticles = (await getCollection('laadpalen'))
  .filter((a) => !a.data.draft && a.data.type !== 'seo-reference')
  .sort((a, b) => {
    const dateA = a.data.publish_date ?? new Date(0);
    const dateB = b.data.publish_date ?? new Date(0);
    return dateB.valueOf() - dateA.valueOf();
  });

const typeLabels: Record<string, string> = {
  pillar: 'Pillar',
  guide: 'Gids',
  informational: 'Informatie',
  comparison: 'Vergelijking',
  homepage: 'Homepage',
};
---

<BaseLayout
  title="Onafhankelijk laadpalen vergelijken"
  description="Vergelijk thuislaadpalen op vermogen, slimme functies en prijs. Inclusief subsidie-info en installatiekosten. Onafhankelijk advies voor Nederlandse elektrische rijders."
  structuredData={structuredData}
>
  <!-- HERO: unique 2-column layout with EV charging illustration -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <span class="hero-eyebrow">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          Laadpaalvergelijker
        </span>
        <h1>De slimme keuze voor jouw<br /><em>thuislaadpaal</em></h1>
        <p class="hero-sub">
          Vergelijk laadpalen op vermogen, slimme functies, prijs en installatiekosten.
          Ontdek hoeveel subsidie jij kunt krijgen.
        </p>
        <div class="hero-stats">
          <div class="stat">
            <span class="stat-num">12+</span>
            <span class="stat-label">Merken vergeleken</span>
          </div>
          <div class="stat">
            <span class="stat-num">€1.400</span>
            <span class="stat-label">Gem. besparing subsidie</span>
          </div>
          <div class="stat">
            <span class="stat-num">100%</span>
            <span class="stat-label">Onafhankelijk</span>
          </div>
        </div>
        <div class="hero-actions">
          <a href="/tools/totaalkosten/" class="btn btn-cta">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            Bereken laadkosten
          </a>
          <a href="/tools/subsidie/" class="btn btn-ghost">Check subsidies &rarr;</a>
        </div>
      </div>
      <div class="hero-visual" aria-hidden="true">
        <!-- EV Charging Station SVG illustration -->
        <svg viewBox="0 0 320 380" fill="none" xmlns="http://www.w3.org/2000/svg" class="ev-illustration">
          <!-- Ground -->
          <ellipse cx="160" cy="355" rx="110" ry="12" fill="rgba(255,255,255,0.08)"/>
          <!-- Charging pole -->
          <rect x="120" y="60" width="80" height="290" rx="16" fill="rgba(255,255,255,0.12)" stroke="rgba(255,255,255,0.25)" stroke-width="2"/>
          <!-- Screen area -->
          <rect x="132" y="80" width="56" height="70" rx="8" fill="rgba(74,222,128,0.25)" stroke="rgba(74,222,128,0.6)" stroke-width="1.5"/>
          <!-- Lightning bolt on screen -->
          <path d="M155 95 L148 110 H158 L145 130 L162 112 H153 L165 95 Z" fill="#4ade80" opacity="0.9"/>
          <!-- Status dots -->
          <circle cx="144" cy="84" r="3" fill="#4ade80"/>
          <circle cx="152" cy="84" r="3" fill="rgba(255,255,255,0.3)"/>
          <circle cx="160" cy="84" r="3" fill="rgba(255,255,255,0.3)"/>
          <!-- Cable connector port -->
          <rect x="136" y="162" width="48" height="28" rx="6" fill="rgba(255,255,255,0.15)" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
          <circle cx="160" cy="176" r="8" fill="rgba(255,255,255,0.2)" stroke="rgba(255,255,255,0.5)" stroke-width="1.5"/>
          <circle cx="160" cy="176" r="3" fill="rgba(255,255,255,0.6)"/>
          <!-- Cable -->
          <path d="M208 176 Q240 176 248 200 Q256 224 240 248 Q228 264 220 276" stroke="rgba(74,222,128,0.7)" stroke-width="5" stroke-linecap="round" fill="none"/>
          <!-- CCS2 connector at cable end -->
          <rect x="208" y="270" width="28" height="36" rx="7" fill="rgba(74,222,128,0.3)" stroke="rgba(74,222,128,0.8)" stroke-width="2"/>
          <circle cx="222" cy="283" r="5" fill="rgba(255,255,255,0.4)"/>
          <circle cx="215" cy="294" r="3.5" fill="rgba(255,255,255,0.3)"/>
          <circle cx="229" cy="294" r="3.5" fill="rgba(255,255,255,0.3)"/>
          <!-- Brand label -->
          <rect x="134" y="206" width="52" height="14" rx="4" fill="rgba(255,255,255,0.1)"/>
          <rect x="138" y="209" width="28" height="8" rx="2" fill="rgba(255,255,255,0.25)"/>
          <!-- Power bars -->
          <rect x="134" y="232" width="10" height="18" rx="2" fill="#4ade80"/>
          <rect x="148" y="226" width="10" height="24" rx="2" fill="#4ade80"/>
          <rect x="162" y="220" width="10" height="30" rx="2" fill="#4ade80" opacity="0.7"/>
          <rect x="176" y="228" width="10" height="22" rx="2" fill="#4ade80" opacity="0.4"/>
          <!-- Glowing base -->
          <rect x="112" y="340" width="96" height="16" rx="8" fill="rgba(74,222,128,0.2)"/>
          <!-- Ambient glow -->
          <ellipse cx="160" cy="176" rx="60" ry="40" fill="rgba(74,222,128,0.05)"/>
        </svg>
        <!-- Floating badge -->
        <div class="float-badge float-badge-1">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#16a34a"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01" stroke="#16a34a" stroke-width="2" fill="none"/></svg>
          <span>Subsidie t/m €2.000</span>
        </div>
        <div class="float-badge float-badge-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          <span>11 kW in 1,5 uur</span>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="trust-bar">
    <div class="container">
      <div class="trust-items">
        <div class="trust-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span>Onafhankelijk getest</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="6" width="18" height="12" rx="2"/><line x1="23" y1="13" x2="23" y2="11"/></svg>
          <span>Alle laadpassen vergeleken</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span>ISDE subsidie info</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span>Bijgewerkt april 2026</span>
        </div>
      </div>
    </div>
  </section>

  <!-- TOOLS HIGHLIGHT -->
  <section class="tools-highlight">
    <div class="container">
      <div class="tools-header">
        <span class="section-tag">Gratis tools</span>
        <h2>Interactieve calculators</h2>
        <p>Bereken je laadkosten, check subsidies en vergelijk laadpalen — persoonlijk advies op basis van jouw situatie.</p>
      </div>
      <div class="tools-cards">
        <a href="/tools/totaalkosten/" class="tcard featured">
          <span class="tcard-icon">⚡</span>
          <span class="tcard-badge">Populairst</span>
          <h3>Totaalkosten Calculator</h3>
          <p>Thuis laden vs publiek vs benzine</p>
        </a>
        <a href="/tools/subsidie/" class="tcard">
          <span class="tcard-icon">💰</span>
          <h3>Subsidie Checker</h3>
          <p>Check jouw subsidie per gemeente</p>
        </a>
        <a href="/tools/vergelijk/" class="tcard">
          <span class="tcard-icon">📊</span>
          <h3>Laadpalen Vergelijken</h3>
          <p>Filter op prijs, vermogen, features</p>
        </a>
        <a href="/tools/installatie/" class="tcard">
          <span class="tcard-icon">🔧</span>
          <h3>Installatie Configurator</h3>
          <p>Bereken je installatiekosten</p>
        </a>
      </div>
    </div>
  </section>

  <!-- QUICK DECISION TOOL (keuzehulp) -->
  <section class="keuzehulp-section">
    <div class="container">
      <div class="keuzehulp-card">
        <div class="keuzehulp-header">
          <span class="section-tag">Keuzehulp</span>
          <h2>Welke laadpaal past bij jou?</h2>
          <p>Beantwoord 3 vragen en ontdek je beste optie</p>
        </div>
        <div class="keuzehulp-questions">
          <div class="kq-step">
            <span class="kq-num">1</span>
            <div class="kq-content">
              <h4>Welk type auto rijd je?</h4>
              <div class="kq-options">
                <a href="/vergelijkingen/" class="kq-opt">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="1" y="10" width="18" height="8" rx="2"/><path d="M5 10V7a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v3"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="14.5" cy="18.5" r="2.5"/></svg>
                  Volledig elektrisch
                </a>
                <a href="/vergelijkingen/" class="kq-opt">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                  Plug-in hybride
                </a>
              </div>
            </div>
          </div>
          <div class="kq-step">
            <span class="kq-num">2</span>
            <div class="kq-content">
              <h4>Hoeveel km rij je gemiddeld per dag?</h4>
              <div class="kq-options">
                <a href="/vergelijkingen/" class="kq-opt">Minder dan 50 km</a>
                <a href="/vergelijkingen/" class="kq-opt">50 – 150 km</a>
                <a href="/vergelijkingen/" class="kq-opt">Meer dan 150 km</a>
              </div>
            </div>
          </div>
          <div class="kq-step">
            <span class="kq-num">3</span>
            <div class="kq-content">
              <h4>Heb je zonnepanelen?</h4>
              <div class="kq-options">
                <a href="/vergelijkingen/" class="kq-opt">Ja, slim laden is belangrijk</a>
                <a href="/vergelijkingen/" class="kq-opt">Nee, basis is genoeg</a>
              </div>
            </div>
          </div>
        </div>
        <div class="keuzehulp-cta">
          <a href="/vergelijkingen/" class="btn btn-cta">Bekijk aanbevolen laadpalen →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- LATEST ARTICLES -->
  {allArticles.length > 0 && (
    <section class="articles-section">
      <div class="container">
        <div class="section-header">
          <span class="section-tag">Gidsen</span>
          <h2>Alles over laadpalen thuis</h2>
          <p>Van aanschaf tot installatie: onze onafhankelijke gidsen helpen je de juiste keuze maken.</p>
        </div>
        <div class="articles-grid">
          {allArticles.slice(0, 6).map((article) => (
            <a href={`/laadpalen/${article.id}/`} class="article-card">
              <div class="article-card-top">
                <span class="badge badge-primary">{typeLabels[article.data.type] || 'Artikel'}</span>
                {article.data.publish_date && (
                  <time class="article-date" datetime={article.data.publish_date.toISOString()}>
                    {article.data.publish_date.toLocaleDateString('nl-NL', { day: 'numeric', month: 'short', year: 'numeric' })}
                  </time>
                )}
              </div>
              <h3>{article.data.title}</h3>
              <p>{article.data.description}</p>
              <span class="article-read-more">Lees meer →</span>
            </a>
          ))}
        </div>
        <div class="view-all">
          <a href="/artikelen/" class="btn btn-primary">Alle artikelen</a>
        </div>
      </div>
    </section>
  )}

  <!-- METHODOLOGY TEASER -->
  <section class="methodology-section">
    <div class="container">
      <div class="methodology-card">
        <div class="methodology-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
        </div>
        <div class="methodology-text">
          <h3>Zo testen wij laadpalen</h3>
          <p>We beoordelen elke laadpaal op 8 criteria: laadsnelheid, slimme functies, gebruiksgemak, app-kwaliteit, subsidie-geschiktheid, garantie, installatievriendelijkheid en prijs-kwaliteit.</p>
        </div>
        <a href="/zo-vergelijken-wij/" class="btn btn-primary">Onze methodologie</a>
      </div>
    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section class="bottom-cta">
    <div class="container">
      <div class="bottom-cta-inner">
        <h2>Klaar om jouw laadpaal te kiezen?</h2>
        <p>Vergelijk alle modellen en vind de laadpaal die past bij jouw auto en situatie.</p>
        <div class="bottom-cta-buttons">
          <a href="/vergelijkingen/" class="btn btn-cta">Vergelijk laadpalen</a>
          <a href="/offerte/" class="btn btn-outline">Offerte aanvragen</a>
        </div>
        <p class="disclaimer">
          <small>Onafhankelijk &middot; Geen voorkeurspositie op basis van commissie &middot; Bijgewerkt april 2026</small>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* HERO */
  .hero {
    background: linear-gradient(135deg, #052e16 0%, #14532d 35%, #166534 65%, #16a34a 100%);
    color: #fff;
    padding: 3rem 0 4rem;
    overflow: hidden;
    position: relative;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 70% 50%, rgba(74,222,128,0.12) 0%, transparent 60%);
    pointer-events: none;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
    position: relative;
  }
  @media (min-width: 900px) {
    .hero { padding: 5rem 0 6rem; }
    .hero-inner { grid-template-columns: 1fr 1fr; gap: 4rem; }
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.875rem;
    background: rgba(74,222,128,0.2);
    border: 1px solid rgba(74,222,128,0.4);
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    color: #bbf7d0;
  }
  .hero h1 {
    color: #fff;
    font-size: 2.25rem;
    line-height: 1.15;
    margin-bottom: 1.25rem;
    font-weight: 800;
  }
  .hero h1 em {
    font-style: normal;
    color: #4ade80;
  }
  @media (min-width: 768px) {
    .hero h1 { font-size: 3rem; }
  }
  .hero-sub {
    font-size: 1.0625rem;
    opacity: 0.85;
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 480px;
  }
  .hero-stats {
    display: flex;
    gap: 2rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .stat-num {
    display: block;
    font-size: 1.5rem;
    font-weight: 800;
    color: #4ade80;
    line-height: 1;
    font-family: var(--font-serif);
  }
  .stat-label {
    display: block;
    font-size: 0.8rem;
    opacity: 0.7;
    margin-top: 0.125rem;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .btn-ghost {
    background: transparent;
    color: #fff;
    border: none;
    padding: 0;
    font-weight: 500;
    opacity: 0.8;
  }
  .btn-ghost:hover {
    opacity: 1;
    box-shadow: none;
    transform: none;
    text-decoration: none;
    color: #4ade80;
  }

  /* EV Illustration */
  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .ev-illustration {
    width: 100%;
    max-width: 280px;
    margin: 0 auto;
    filter: drop-shadow(0 20px 40px rgba(74,222,128,0.15));
  }
  @media (min-width: 900px) {
    .ev-illustration { max-width: 320px; }
  }
  .float-badge {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.875rem;
    background: rgba(255,255,255,0.95);
    border-radius: 999px;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #0f1a0f;
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
    white-space: nowrap;
  }
  .float-badge-1 { top: 10%; left: -10px; }
  .float-badge-2 { bottom: 15%; right: -10px; }

  /* TRUST BAR */
  .trust-bar {
    background: #fff;
    border-bottom: 1px solid var(--color-border);
    padding: 1rem 0;
  }
  .trust-items {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-light);
  }
  .trust-item svg { color: var(--color-primary); }
  .trust-divider {
    width: 1px;
    height: 1.25rem;
    background: var(--color-border);
  }
  @media (max-width: 600px) { .trust-divider { display: none; } }

  /* TOOLS HIGHLIGHT */
  .tools-highlight { padding: 3rem 0; background: #f0fdf4; }
  .tools-header { text-align: center; margin-bottom: 2rem; }
  .tools-header h2 { margin: 0.5rem 0; font-size: 1.75rem; }
  .tools-header p { color: var(--color-text-light); font-size: 1rem; margin: 0; }
  .tools-cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }
  .tcard {
    background: white; border: 2px solid #e5e7eb; border-radius: 14px;
    padding: 1.5rem; text-decoration: none; color: inherit;
    text-align: center; transition: all 0.15s; position: relative;
  }
  .tcard:hover { border-color: #16a34a; box-shadow: 0 4px 12px rgba(22,163,74,0.1); transform: translateY(-2px); }
  .tcard.featured { border-color: #16a34a; background: white; }
  .tcard-icon { font-size: 2rem; display: block; margin-bottom: 0.5rem; }
  .tcard-badge {
    position: absolute; top: -8px; right: 12px;
    background: #16a34a; color: white; font-size: 0.68rem; font-weight: 700;
    padding: 2px 10px; border-radius: 12px;
  }
  .tcard h3 { margin: 0 0 0.25rem; font-size: 0.95rem; color: #111827; }
  .tcard p { margin: 0; font-size: 0.8rem; color: #6b7280; }
  @media (max-width: 767px) { .tools-cards { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .tools-cards { grid-template-columns: 1fr; } }

  /* KEUZEHULP */
  .keuzehulp-section {
    padding: 4rem 0;
    background: var(--color-bg-alt);
  }
  .section-tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: var(--color-primary-light);
    color: var(--color-primary-dark);
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.75rem;
  }
  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .section-header p {
    color: var(--color-text-light);
    margin-top: 0.5rem;
    font-size: 1.0625rem;
  }
  .keuzehulp-card {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 1.25rem;
    padding: 2.5rem 2rem;
    max-width: 800px;
    margin: 0 auto;
    box-shadow: var(--shadow-md);
  }
  .keuzehulp-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .keuzehulp-header h2 { margin-bottom: 0.5rem; }
  .keuzehulp-header p { color: var(--color-text-light); }
  .keuzehulp-questions {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }
  .kq-step {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }
  .kq-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    min-width: 36px;
    background: var(--color-primary);
    color: #fff;
    border-radius: 50%;
    font-weight: 700;
    font-size: 0.9375rem;
    font-family: var(--font-serif);
