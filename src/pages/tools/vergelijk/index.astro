---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import laadpalenData from '../../../data/laadpalen.json';

const laadpalen = laadpalenData.laadpalen;
const badgeLabels: Record<string, string> = {
  'beste-koop': '🏆 Beste koop',
  'premium': '⭐ Premium',
  'meest-compact': '📏 Meest compact',
  'beste-app': '📱 Beste app',
};
---

<BaseLayout
  title="Laadpalen Vergelijken — Filter op Prijs, Vermogen en Features"
  description="Vergelijk alle thuislaadpalen in Nederland. Filter op prijs, vermogen, smart features en meer."
>
  <main class="tool-page">
    <div class="container">
      <div class="tool-header">
        <a href="/tools/" class="back-link">← Alle tools</a>
        <h1>Laadpalen Vergelijken</h1>
        <p class="tool-intro">Filter en sorteer alle thuislaadpalen. Vind de beste match voor jouw situatie.</p>
      </div>

      <div class="filters card">
        <div class="filter-row">
          <div class="filter-item">
            <label for="filterVermogen">Vermogen</label>
            <select id="filterVermogen">
              <option value="">Alle</option>
              <option value="3.7">3,7 kW (1-fase)</option>
              <option value="7.4">7,4 kW (1-fase)</option>
              <option value="11">11 kW (3-fase)</option>
              <option value="22">22 kW (3-fase)</option>
            </select>
          </div>
          <div class="filter-item">
            <label for="filterMaxPrijs">Max prijs</label>
            <select id="filterMaxPrijs">
              <option value="">Geen limiet</option>
              <option value="500">Tot €500</option>
              <option value="750">Tot €750</option>
              <option value="1000">Tot €1.000</option>
              <option value="1500">Tot €1.500</option>
            </select>
          </div>
          <div class="filter-item">
            <label for="filterSmart">Smart</label>
            <select id="filterSmart">
              <option value="">Alle</option>
              <option value="true">Alleen smart</option>
              <option value="false">Niet-smart</option>
            </select>
          </div>
          <div class="filter-item">
            <label for="filterZon">Zonnepaneel integratie</label>
            <select id="filterZon">
              <option value="">Alle</option>
              <option value="true">Ja</option>
            </select>
          </div>
        </div>
        <div class="result-count" id="resultCount"></div>
      </div>

      <div class="table-wrap card">
        <table class="compare-table" id="compareTable">
          <thead>
            <tr>
              <th class="sortable" data-col="merk">Laadpaal <span class="arrow">↕</span></th>
              <th class="sortable" data-col="prijs">Prijs <span class="arrow">↕</span></th>
              <th class="sortable" data-col="vermogen">Vermogen <span class="arrow">↕</span></th>
              <th>Smart</th>
              <th>Features</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="tableBody"></tbody>
        </table>
      </div>
    </div>
  </main>

  <script is:inline define:vars={{ laadpalen, badgeLabels }}>
    let sortCol = 'prijs';
    let sortAsc = true;

    const filters = {
      vermogen: document.getElementById('filterVermogen'),
      maxPrijs: document.getElementById('filterMaxPrijs'),
      smart: document.getElementById('filterSmart'),
      zon: document.getElementById('filterZon'),
    };

    Object.values(filters).forEach(f => f.addEventListener('change', render));
    document.querySelectorAll('.sortable').forEach(th => {
      th.addEventListener('click', () => {
        const col = th.dataset.col;
        if (sortCol === col) { sortAsc = !sortAsc; } else { sortCol = col; sortAsc = true; }
        document.querySelectorAll('.sortable .arrow').forEach(a => a.textContent = '↕');
        th.querySelector('.arrow').textContent = sortAsc ? '↑' : '↓';
        render();
      });
    });

    function render() {
      let items = [...laadpalen];

      const fv = filters.vermogen.value;
      if (fv) items = items.filter(l => l.vermogen_kw === parseFloat(fv));

      const fp = filters.maxPrijs.value;
      if (fp) items = items.filter(l => l.prijs_eur <= parseInt(fp));

      const fs = filters.smart.value;
      if (fs) items = items.filter(l => String(l.smart) === fs);

      const fz = filters.zon.value;
      if (fz) items = items.filter(l => l.zonnepaneel_integratie === true);

      items.sort((a, b) => {
        let va, vb;
        if (sortCol === 'merk') { va = a.merk + a.model; vb = b.merk + b.model; }
        else if (sortCol === 'prijs') { va = a.prijs_eur; vb = b.prijs_eur; }
        else if (sortCol === 'vermogen') { va = a.vermogen_kw; vb = b.vermogen_kw; }
        else { va = a[sortCol]; vb = b[sortCol]; }
        if (typeof va === 'string') return sortAsc ? va.localeCompare(vb) : vb.localeCompare(va);
        return sortAsc ? va - vb : vb - va;
      });

      document.getElementById('resultCount').textContent = items.length + ' laadpalen gevonden';

      const tbody = document.getElementById('tableBody');
      tbody.innerHTML = items.map(l => {
        const badge = l.badge && badgeLabels[l.badge] ? `<span class="badge">${badgeLabels[l.badge]}</span>` : '';
        const features = [];
        if (l.load_balancing) features.push('Load balancing');
        if (l.mid_meter) features.push('MID meter');
        if (l.zonnepaneel_integratie) features.push('Zon integratie');
        if (l.app) features.push(l.app);

        return `<tr>
          <td>
            <strong>${l.merk} ${l.model}</strong>
            ${badge}
            <div class="cell-note">${l.aansluiting}</div>
          </td>
          <td><strong>€${l.prijs_eur.toLocaleString('nl-NL')}</strong></td>
          <td>${l.vermogen_kw} kW</td>
          <td>${l.smart ? '<span class="yes">✓</span>' : '<span class="no">✗</span>'}</td>
          <td><div class="feature-tags">${features.map(f => `<span class="tag">${f}</span>`).join('')}</div></td>
          <td>${l.affiliate_url ? `<a href="${l.affiliate_url}" target="_blank" rel="noopener" class="btn-sm">Bekijk →</a>` : '<span class="no-link">—</span>'}</td>
        </tr>`;
      }).join('');
    }

    render();
  </script>

  <style>
    .tool-page { padding: 2rem 0 4rem; }
    .tool-header { margin-bottom: 2rem; }
    .back-link { color: var(--color-text-light); font-size: 0.875rem; }
    .tool-header h1 { margin: 0.5rem 0 0.5rem; font-size: 2rem; }
    .tool-intro { color: var(--color-text-light); font-size: 1.05rem; margin: 0; }
    .card { background: white; border: 1px solid #e5e7eb; border-radius: 16px; padding: 1.5rem; margin-bottom: 1.5rem; }

    .filter-row { display: flex; gap: 1rem; flex-wrap: wrap; }
    .filter-item { flex: 1; min-width: 140px; }
    .filter-item label { display: block; font-weight: 600; font-size: 0.8rem; margin-bottom: 0.3rem; color: #374151; }
    .filter-item select { width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 8px; font-size: 0.9rem; }
    .result-count { margin-top: 0.75rem; font-size: 0.85rem; color: #6b7280; }

    .table-wrap { overflow-x: auto; }
    .compare-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    .compare-table th {
      text-align: left; padding: 0.75rem 0.5rem; border-bottom: 2px solid #e5e7eb;
      font-size: 0.8rem; color: #6b7280; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;
    }
    .compare-table th.sortable { cursor: pointer; user-select: none; }
    .compare-table th.sortable:hover { color: #16a34a; }
    .arrow { font-size: 0.75rem; }
    .compare-table td { padding: 0.75rem 0.5rem; border-bottom: 1px solid #f3f4f6; vertical-align: top; }
    .cell-note { font-size: 0.8rem; color: #9ca3af; }
    .badge { display: inline-block; background: #f0fdf4; color: #16a34a; font-size: 0.72rem; font-weight: 600; padding: 2px 8px; border-radius: 12px; margin-left: 0.5rem; }
    .yes { color: #16a34a; font-weight: 700; }
    .no { color: #d1d5db; }

    .feature-tags { display: flex; flex-wrap: wrap; gap: 0.3rem; }
    .tag { background: #f3f4f6; color: #374151; font-size: 0.72rem; padding: 2px 8px; border-radius: 8px; }

    .btn-sm {
      display: inline-block; padding: 0.4rem 0.8rem; background: #16a34a; color: white;
      border-radius: 6px; font-size: 0.8rem; font-weight: 600; text-decoration: none; white-space: nowrap;
    }
    .btn-sm:hover { background: #15803d; }
  </style>
</BaseLayout>
